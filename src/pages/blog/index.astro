---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.data.published)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

const cardStyles = [
  { bg: 'background: #1B4F52;', titleColor: 'color: #FAF7F2;', metaColor: 'color: rgba(250, 247, 242, 0.7);' },
  { bg: 'background: #E8D5B7;', titleColor: 'color: #1B4F52;', metaColor: 'color: rgba(27, 79, 82, 0.6);' },
  { bg: 'background: linear-gradient(135deg, #2A7F62 0%, #1B4F52 100%);', titleColor: 'color: #FAF7F2;', metaColor: 'color: rgba(250, 247, 242, 0.7);' },
];

function getCardStyle(index: number) {
  return cardStyles[index % cardStyles.length];
}
---

<Layout title="Blog — Shoreline Scholars" description="Stories, reflections, and updates from our learning community in Indialantic, Florida.">
  <Header />

  <!-- ═══ HERO ═══ -->
  <section class="relative flex items-center justify-center text-center px-6"
    style="padding-top: 10rem; padding-bottom: 6rem; background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="font-heading text-shell-white text-5xl md:text-6xl font-medium mb-4">From the Shoreline</h1>
      <p class="font-body font-light text-shell-white/80 text-lg md:text-xl tracking-wide max-w-xl mx-auto">
        Stories, reflections, and updates from our learning community
      </p>
    </div>
  </section>

  <!-- ═══ POSTS ═══ -->
  <section class="bg-shell-white py-24">
    <div class="max-w-4xl mx-auto px-6">
      {posts.length > 0 ? (
        <div class="flex flex-col" style="gap: 2rem;">
          {posts.map((post, i) => {
            const style = getCardStyle(i);
            return (
              <article class="rounded-xl shadow overflow-hidden">
                <a href={`/blog/${post.slug}`} class="block hover:opacity-90 transition-opacity" style={style.bg}>
                  <div class="py-10 px-8 md:px-10">
                    <h2 class="font-heading text-2xl md:text-3xl font-medium mb-2" style={style.titleColor}>{post.data.title}</h2>
                    <p class="font-body font-light text-sm" style={style.metaColor}>
                      {formatDate(post.data.date)}
                    </p>
                  </div>
                </a>
                <div class="bg-shell-white p-8 md:p-10">
                  <p class="font-body font-medium text-driftwood text-sm mb-3">{post.data.author}</p>
                  <p class="font-body text-[0.95rem] text-deep-sea/70 leading-relaxed mb-4 line-clamp-3">{post.data.description}</p>
                  <a href={`/blog/${post.slug}`} class="font-body font-medium text-shoreline text-sm hover:text-deep-sea transition-colors">
                    Read More &rarr;
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="font-body text-driftwood text-lg">No posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </section>

  <CallToAction
    heading="Want to stay connected?"
    description="Reach out to learn more about upcoming events, programs, and ways to get involved with Shoreline Scholars."
  />

  <Footer />
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
