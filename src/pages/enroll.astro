---
import Layout from '../layouts/Layout.astro';

const target = 'https://tally.so/r/WOPbpN?program=Rooted%20Learning';
---

<Layout title="Enrollment — Shoreline Scholars" description="Redirecting you to the Shoreline Scholars enrollment form.">

  <section class="relative flex items-center justify-center text-center px-6"
    style="min-height: 100vh; background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>

    <div id="loading-state" class="relative z-10 max-w-md mx-auto">
      <img
        src="/logos/mark-white.png"
        alt="Shoreline Scholars"
        class="breathe-logo mx-auto mb-10"
        width="80"
        height="80"
      />
      <p class="font-body text-shell-white/80 text-base md:text-lg leading-relaxed mb-8">
        Taking you to the enrollment form…
      </p>
      <p class="fallback-fade font-body text-shell-white/50 text-sm">
        If you are not redirected automatically,
        <a href={target} class="text-shell-white/70 underline hover:text-shell-white transition-colors">click here</a>.
      </p>
    </div>

    <noscript>
      <div class="relative z-10 max-w-md mx-auto">
        <img
          src="/logos/mark-white.png"
          alt="Shoreline Scholars"
          class="mx-auto mb-10"
          width="80"
          height="80"
        />
        <p class="font-body text-shell-white/80 text-base md:text-lg leading-relaxed mb-8">
          Open the enrollment form to get started.
        </p>
        <a href={target}
          class="inline-block font-body font-semibold text-[0.8rem] uppercase tracking-[0.15em] px-8 py-3 rounded-[6px] transition-all duration-200 bg-sunrise text-white hover:brightness-110">
          Open Enrollment Form
        </a>
      </div>
    </noscript>
  </section>

</Layout>

<script is:inline define:vars={{ target }}>
  setTimeout(function () {
    window.location.replace(target);
  }, 1200);
</script>

<style>
  .breathe-logo {
    animation: breathe 2.5s ease-in-out infinite;
  }

  @keyframes breathe {
    0% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.08); opacity: 1; }
    100% { transform: scale(1); opacity: 0.7; }
  }

  .fallback-fade {
    opacity: 0;
    animation: fade-in 0.5s ease-in forwards;
    animation-delay: 1.2s;
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
