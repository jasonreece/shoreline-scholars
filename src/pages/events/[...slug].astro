---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CallToAction from '../../components/CallToAction.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const tallyProgram = entry.data.tallyProgram || '';
const capacity = entry.data.capacity || 0;
const googleApiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY || '';

function formatDate(dateStr: string): string {
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
}
---

<Layout title={`${entry.data.title} — Shoreline Scholars`} description={entry.data.description}>
  <Header />

  <!-- ═══ HERO ═══ -->
  <section class="relative flex items-center justify-center text-center px-6"
    style="padding-top: 10rem; padding-bottom: 4rem; background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="font-heading text-shell-white text-4xl md:text-5xl font-medium mb-4">{entry.data.title}</h1>
      <p class="font-body font-light text-shell-white/80 text-base md:text-lg tracking-wide">
        {formatDate(entry.data.date)} &middot; {entry.data.time}
      </p>
      <p class="font-body font-light text-shell-white/70 text-sm mt-2 tracking-wide">
        {entry.data.location}
      </p>
    </div>
  </section>

  <!-- ═══ CONTENT ═══ -->
  <section class="bg-shell-white py-16">
    <div class="max-w-3xl mx-auto px-6">

      {entry.data.image && (
        <div class="mb-12 flex justify-center">
          <img
            src={entry.data.image}
            alt={entry.data.title}
            class="max-w-2xl w-full rounded-xl shadow"
          />
        </div>
      )}

      <div class="event-content">
        <Content />
      </div>

      {capacity > 0 && tallyProgram && (
        <div id="seat-counter" class="mt-10 text-center" style="display: none;"
          data-capacity={capacity}
          data-program={tallyProgram}
          data-api-key={googleApiKey}
          data-sheet-id="1UxFKX9kJBOU4wLeyVzQiaivnflQB0aR-CzA7DGzyPQo"
        >
          <p class="font-body text-sm text-driftwood mb-4">
            <span id="seat-text"></span>
          </p>
        </div>
      )}

      {tallyProgram && entry.data.cta && (
        <div class="mt-4 text-center">
          <button
            id="tally-enroll-btn"
            data-tally-program={tallyProgram}
            class="inline-block font-body font-semibold text-[0.8rem] uppercase tracking-[0.15em] px-8 py-3 rounded-[6px] transition-all duration-200 cursor-pointer bg-sunrise text-white hover:brightness-110"
          >
            {entry.data.cta}
          </button>
        </div>
      )}

      {!tallyProgram && entry.data.cta && entry.data.ctaLink && (
        <div class="mt-10 text-center">
          <a
            href={entry.data.ctaLink}
            target={entry.data.ctaLink.startsWith('http') ? '_blank' : undefined}
            rel={entry.data.ctaLink.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="inline-block font-body font-semibold text-[0.8rem] uppercase tracking-[0.15em] px-8 py-3 rounded-[6px] transition-all duration-200 cursor-pointer bg-sunrise text-white hover:brightness-110"
          >
            {entry.data.cta}
          </a>
        </div>
      )}

      <div class="mt-12">
        <a href="/events" class="font-body font-medium text-shoreline text-sm hover:text-deep-sea transition-colors">
          &larr; Back to All Events
        </a>
      </div>
    </div>
  </section>

  <CallToAction
    heading="Want to stay in the loop?"
    description="Reach out to learn more about upcoming events, programs, and ways to get involved with Shoreline Scholars."
  />

  <Footer />
</Layout>

<script is:inline>
  (function () {
    var btn = document.getElementById('tally-enroll-btn');
    if (!btn) return;

    var program = btn.getAttribute('data-tally-program');

    btn.addEventListener('click', function () {
      if (typeof Tally === 'undefined') {
        window.open('https://tally.so/r/WOPbpN?program=' + encodeURIComponent(program), '_blank');
        return;
      }

      Tally.openPopup('WOPbpN', {
        layout: 'default',
        width: 480,
        overlay: true,
        hiddenFields: {
          program: program
        }
      });
    });
  })();
</script>

<script is:inline>
  (function () {
    var counter = document.getElementById('seat-counter');
    if (!counter) return;

    var capacity = parseInt(counter.getAttribute('data-capacity'), 10);
    var program = counter.getAttribute('data-program');
    var apiKey = counter.getAttribute('data-api-key');
    var sheetId = counter.getAttribute('data-sheet-id');

    if (!capacity || !program || !apiKey) return;

    var url = 'https://sheets.googleapis.com/v4/spreadsheets/' + sheetId + '/values/Sheet1!A:C?key=' + apiKey;

    fetch(url)
      .then(function (res) { return res.json(); })
      .then(function (data) {
        console.log('[Seats] Google Sheets response:', data);
        if (!data.values) return;

        var enrolled = 0;
        for (var i = 1; i < data.values.length; i++) {
          var row = data.values[i];
          if (row[0] === program) {
            // Try column C first, fall back to column B
            enrolled = parseInt(row[2], 10) || parseInt(row[1], 10) || 0;
            break;
          }
        }

        var remaining = Math.max(0, capacity - enrolled);
        var textEl = document.getElementById('seat-text');

        if (enrolled === 0) {
          // No enrollments yet — don't show anything
        } else if (remaining === 0) {
          textEl.textContent = 'This program is currently full.';
          counter.style.display = '';
        } else if (remaining <= 3) {
          textEl.textContent = remaining + ' of ' + capacity + ' spots remaining — almost full';
          counter.style.display = '';
        } else {
          textEl.textContent = remaining + ' of ' + capacity + ' spots remaining';
          counter.style.display = '';
        }

        console.log('[Seats] ' + program + ': ' + enrolled + ' enrolled, ' + remaining + ' remaining');
      })
      .catch(function (err) {
        console.warn('[Seats] Failed to fetch enrollment data:', err);
      });
  })();
</script>

<style>
  .event-content :global(p) {
    font-family: 'Raleway', system-ui, sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: #4A5859;
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .event-content :global(strong) {
    font-weight: 600;
    color: #1B4F52;
  }

  .event-content :global(h2) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    color: #1B4F52;
    font-size: 1.8rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .event-content :global(h3) {
    font-family: 'Cormorant Garamond', Georgia, serif;
    color: #1B4F52;
    font-size: 1.4rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .event-content :global(ul) {
    font-family: 'Raleway', system-ui, sans-serif;
    font-size: 0.95rem;
    color: #4A5859;
    line-height: 1.7;
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .event-content :global(ol) {
    font-family: 'Raleway', system-ui, sans-serif;
    font-size: 0.95rem;
    color: #4A5859;
    line-height: 1.7;
    list-style-type: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .event-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .event-content :global(li strong) {
    font-weight: 600;
    color: #1B4F52;
  }

  .event-content :global(a) {
    color: #2A7F62;
    text-decoration: none;
    transition: text-decoration 0.2s;
  }

  .event-content :global(a:hover) {
    text-decoration: underline;
  }

  .event-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .event-content :global(thead) {
    display: none;
  }

  .event-content :global(tr) {
    border-bottom: 1px solid rgba(232, 213, 183, 0.4);
  }

  .event-content :global(tr:last-child) {
    border-bottom: none;
  }

  .event-content :global(td) {
    font-family: 'Raleway', system-ui, sans-serif;
    font-size: 0.92rem;
    color: #4A5859;
    line-height: 1.6;
    padding: 0.75rem 0;
    vertical-align: top;
  }

  .event-content :global(td:first-child) {
    font-family: 'Raleway', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: #B8977E;
    white-space: nowrap;
    width: 6rem;
    padding-right: 1.25rem;
  }

  .event-content :global(td strong) {
    font-weight: 600;
    color: #1B4F52;
  }
</style>
