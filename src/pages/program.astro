---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionNav from '../components/SectionNav.astro';
import CallToAction from '../components/CallToAction.astro';
---

<Layout title="Our Program — Shoreline Scholars" description="The Rooted Learning Program: a nature-oriented, whole-child enrichment program for homeschool families in Melbourne Beach, Indialantic, and the greater Brevard County Space Coast.">
  <Header />
  <SectionNav sections={[
    { label: 'Overview', id: 'overview' },
    { label: 'Curriculum', id: 'curriculum' },
    { label: 'Schedule', id: 'weekly-schedule' },
    { label: 'Daily Schedules', id: 'daily-schedules' },
    { label: 'Electives', id: 'electives' },
    { label: 'Field Trips', id: 'field-trips' },
    { label: 'Family Partnership', id: 'family-partnership' },
    { label: 'Admissions', id: 'admissions' },
  ]} />

  <!-- ═══ HERO ═══ -->
  <section class="relative flex items-center justify-center text-center px-6"
    style="padding-top: 12rem; padding-bottom: 6rem; background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="font-heading text-shell-white text-5xl md:text-6xl font-medium mb-4">Our Program</h1>
      <p class="font-body font-light text-shell-white/80 text-lg md:text-xl tracking-wide max-w-xl mx-auto">
        The Rooted Learning Program
      </p>
    </div>
  </section>

  <!-- ═══ OVERVIEW ═══ -->
  <section id="overview" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Overview</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <p class="text-[0.95rem] leading-relaxed mb-6 max-w-3xl mx-auto">
        At Shoreline Scholars, we provide a thoughtfully designed, holistic learning experience that supports both academic growth and whole-child development.
      </p>
      <p class="text-[0.95rem] leading-relaxed mb-6 max-w-3xl mx-auto">
        For families enrolled in our full-time 3-day/week program, all major academic subjects are covered and provided through engaging, thoughtfully created workbooks. The Rooted Learning Program runs Wednesday through Friday during both the Fall semester (August through December) and Spring semester (January through May). Families may enroll in a 1-day, 2-day, or 3-day weekly schedule.
      </p>
      <p class="text-[0.95rem] leading-relaxed mb-6 max-w-3xl mx-auto">
        The program is led by a team whose credentials include a doctorate-level Licensed Mental Health Counselor and 20 years of classroom teaching experience.
      </p>
      <p class="text-[0.95rem] leading-relaxed max-w-3xl mx-auto">
        Based in Melbourne Beach, Florida, we welcome homeschool families from across the Space Coast — including Indialantic, Satellite Beach, Indian Harbour Beach, Melbourne, and the greater Brevard County area.
      </p>

      <figure class="mt-16">
        <img
          src="/images/program/weekly-schedule.jpg"
          alt="Shoreline Scholars weekly class schedule — Tuesday electives plus Wednesday, Thursday, and Friday classes for the Young Explorers, Curious Learners, and Confident Leaders groups"
          class="w-full rounded-2xl shadow"
        />
        <figcaption class="font-body text-driftwood text-xs uppercase tracking-wider text-center mt-4">
          Weekly Class Schedule
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ═══ CURRICULUM ═══ -->
  <section id="curriculum" class="py-24 md:py-32" style="background: rgba(232, 213, 183, 0.15);">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Curriculum and Academic Scope</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <p class="text-[0.95rem] leading-relaxed mb-10 max-w-3xl mx-auto">
        The Rooted Learning Program delivers comprehensive academic instruction across all major subject areas. Students enrolled in the full-time 3-day schedule receive instruction in the following disciplines:
      </p>

      <div class="max-w-3xl mx-auto" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <!-- Year-Round -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Both Fall and Spring Semesters</h3>
          <p class="font-body text-driftwood text-xs uppercase tracking-wider mb-3">August through May</p>
          <ul class="subject-list">
            <li>English Literature</li>
            <li>Art</li>
            <li>Science (Chemistry, Physics, Biology, Environmental Science, Animal Science, Marine Biology, Plant Studies, and Oceanography)</li>
          </ul>
          <p class="text-[0.92rem] leading-relaxed mt-4 text-driftwood italic">
            Core science rotates by term: Chemistry (T1), Physics (T2), Biology (T3), Environmental Science (T4). Animal Science, Marine Biology, Plant Studies, and Oceanography are covered on Friday nature days throughout the year.
          </p>
          <div class="book-list">
            <p class="font-body text-deep-sea text-xs uppercase tracking-wider font-semibold mb-3">Required Books for English Literature</p>
            <div class="book-term">
              <span class="book-term-label">Term 1</span>
              <ul class="subject-list">
                <li><em>Charlotte's Web</em> by E.B. White</li>
                <li><em>Because of Winn-Dixie</em> by Kate DiCamillo</li>
              </ul>
            </div>
            <div class="book-term">
              <span class="book-term-label">Term 2</span>
              <ul class="subject-list">
                <li><em>The Tale of Despereaux</em> by Kate DiCamillo</li>
                <li><em>Mr. Popper's Penguins</em> by Richard &amp; Florence Atwater</li>
              </ul>
            </div>
            <div class="book-term">
              <span class="book-term-label">Term 3</span>
              <ul class="subject-list">
                <li><em>The One and Only Ivan</em> by Katherine Applegate</li>
                <li><em>Frindle</em> by Andrew Clements</li>
              </ul>
            </div>
            <div class="book-term">
              <span class="book-term-label">Term 4</span>
              <ul class="subject-list">
                <li><em>Bridge to Terabithia</em> by Katherine Paterson</li>
                <li><em>Matilda</em> by Roald Dahl</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Fall Semester -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Fall Semester <span class="font-body text-driftwood text-xs uppercase tracking-wider">(T1–T2)</span></h3>
          <p class="font-body text-driftwood text-xs uppercase tracking-wider mb-3">August through December</p>
          <ul class="subject-list">
            <li>Civics and Government Studies</li>
            <li>Creative Writing</li>
            <li>Critical Thinking</li>
          </ul>
        </div>

        <!-- Spring Semester -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Spring Semester <span class="font-body text-driftwood text-xs uppercase tracking-wider">(T3–T4)</span></h3>
          <p class="font-body text-driftwood text-xs uppercase tracking-wider mb-3">January through May</p>
          <ul class="subject-list">
            <li>History</li>
            <li>Geography</li>
            <li>Eastern and Western Philosophy</li>
          </ul>
        </div>

        <!-- Enrichment & Real-World Learning -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Enriched, Real-World Learning</h3>
          <p class="text-[0.95rem] leading-relaxed mb-4">
            In addition to these foundational subjects, Shoreline Scholars offers enriched, real-world learning opportunities that extend beyond traditional academics. Students are exposed to and engaged in:
          </p>
          <ul class="subject-list">
            <li>Daily Reading and Writing Concepts</li>
            <li>Mathematics Integration</li>
            <li>Entrepreneurship (Business/Economic Principles and Financial Literacy)</li>
            <li>Horticulture</li>
            <li>Carpentry</li>
          </ul>
          <p class="text-[0.92rem] leading-relaxed mt-4 text-driftwood italic">
            These areas are introduced in age-appropriate, hands-on ways that encourage critical thinking, creativity, and practical life skills. Students will have opportunities to participate in entrepreneurial events, designing and selling handmade products.
          </p>
        </div>
      </div>

      <!-- Instructional Delivery -->
      <div class="max-w-3xl mx-auto mt-12">
        <h3 class="font-heading text-deep-sea text-xl mb-4">Instructional Delivery</h3>
        <p class="text-[0.95rem] leading-relaxed">
          Academic content is delivered through thoughtfully created workbooks and guided instruction. The program serves three age tiers with differentiated schedules: <strong class="text-deep-sea">Young Explorers</strong> (ages 5–7) receive shorter 30-minute lesson blocks with more structured play and movement; <strong class="text-deep-sea">Curious Learners</strong> (ages 8–10) and <strong class="text-deep-sea">Confident Leaders</strong> (ages 11–13) engage in 45-minute instructional periods with self-directed project time and, for the oldest tier, applied math and entrepreneurship integration. All three tiers benefit from daily outdoor learning, including gardening, gentle exercise, and coastal exploration.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ SCHEDULE ═══ -->
  <section id="weekly-schedule" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Program Schedule</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="max-w-3xl mx-auto mb-10">
        <p class="text-[0.95rem] leading-relaxed mb-4">
          <strong class="text-deep-sea">Wednesday and Thursday:</strong> 9:30 AM to 2:00 PM<br />
          <span class="text-driftwood text-[0.88rem]">St. Sebastian by-the-Sea, 2010 Oak St, Melbourne Beach, FL</span>
        </p>
        <p class="text-[0.95rem] leading-relaxed">
          <strong class="text-deep-sea">Friday (Nature Day):</strong> 9:30 AM to 2:00 PM<br />
          <span class="text-driftwood text-[0.88rem]">Paradise Beach (August and September, April and May) &middot; Orlando Park (October through March)</span>
        </p>
      </div>

      <div class="max-w-3xl mx-auto" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div class="schedule-card">
          <div class="schedule-card-header">
            <h3 class="font-heading text-deep-sea text-xl">Wednesday</h3>
            <div class="schedule-meta">
              <span class="age-badge">Ages 5–13</span>
              <span class="time-badge">9:30 AM – 2:00 PM</span>
            </div>
          </div>
          <p class="text-[0.95rem] leading-relaxed mt-3">
            Core academics (English Literature, Art, and Science) with entrepreneurship and self-directed project time. Three age tiers run differentiated schedules: <strong class="text-deep-sea">Young Explorers</strong> (5–7) focus on Math, Reading/Writing &amp; Public Speaking, Science, and Art; <strong class="text-deep-sea">Curious Learners</strong> (8–10) and <strong class="text-deep-sea">Confident Leaders</strong> (11–13) follow the core academic rotation.
          </p>
        </div>

        <div class="schedule-card">
          <div class="schedule-card-header">
            <h3 class="font-heading text-deep-sea text-xl">Thursday</h3>
            <div class="schedule-meta">
              <span class="age-badge">Ages 5–13</span>
              <span class="time-badge">9:30 AM – 2:00 PM</span>
            </div>
          </div>
          <p class="text-[0.95rem] leading-relaxed mt-3">
            Humanities rotation: Civics/Government (T1–T2) → History (T3–T4), Critical Thinking (T1–T2) → Geography (T3–T4), Creative Writing (T1–T2) → Eastern &amp; Western Philosophy (T3–T4). Confident Leaders close the day with Applied Math &amp; Entrepreneurship; Young Explorers follow a parallel structure with the same enrichment integrated.
          </p>
        </div>

        <div class="schedule-card">
          <div class="schedule-card-header">
            <h3 class="font-heading text-deep-sea text-xl">Friday <span class="font-body text-driftwood text-xs uppercase tracking-wider">&mdash; Nature Day</span></h3>
            <div class="schedule-meta">
              <span class="age-badge">All Ages 5–13</span>
              <span class="time-badge">9:30 AM – 2:00 PM</span>
            </div>
          </div>
          <p class="text-[0.95rem] leading-relaxed mt-3">
            All ages come together for nature-focused science instruction. <strong class="text-deep-sea">Ocean Lab</strong> (August–September, April–May) at Paradise Beach covers Oceanography and Marine Biology. <strong class="text-deep-sea">Park Lab</strong> (October–March) at Orlando Park covers Animal Science and Plant Studies.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DAILY SCHEDULES ═══ -->
  <section id="daily-schedules" class="py-24 md:py-32" style="background: rgba(232, 213, 183, 0.15);">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Detailed Daily Schedules</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="max-w-3xl mx-auto" style="display: flex; flex-direction: column; gap: 1.25rem;">

        <!-- Wednesday — Young Explorers -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Wednesday — Young Explorers</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 5–7</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gentle mind and body exercises, guided play, gardening outside (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:00 AM</span><span>Academic Lesson 1 (30 min) — Math</span></div>
              <div class="schedule-row"><span class="schedule-time">10:30 AM</span><span>Rest and play outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (30 min) — Reading, Writing &amp; Public Speaking</span></div>
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Board games (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Lunch and free play (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (30 min) — Chemistry (T1) · Physics (T2) · Biology (T3) · Environmental Science (T4)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:00 PM</span><span>Rest and play (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:20 PM</span><span>Academic Lesson 4 (30 min) — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">1:50 PM</span><span>Clean up and closing circle (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Wednesday — Curious Learners -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Wednesday — Curious Learners</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 8–10</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gardening and gentle exercise outside (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:00 AM</span><span>Academic Lesson 1 (45 min) — English Literature</span></div>
              <div class="schedule-row"><span class="schedule-time">10:45 AM</span><span>Rest (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (45 min) — Chemistry (T1) · Physics (T2) · Biology (T3) · Environmental Science (T4)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Lunch and free play (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (45 min) — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">1:15 PM</span><span>Academic Lesson 4 (45 min) — Entrepreneurship / self-projects with guidance / individual tutoring</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Wednesday — Confident Leaders -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Wednesday — Confident Leaders</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 11–13</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gardening and gentle exercise outside (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:00 AM</span><span>Academic Lesson 1 (45 min) — Chemistry (T1) · Physics (T2) · Biology (T3) · Environmental Science (T4)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:45 AM</span><span>Rest (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (45 min) — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Lunch and free play, indoor or outdoor (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (45 min) — Entrepreneurship / self-projects with guidance / individual tutoring</span></div>
              <div class="schedule-row"><span class="schedule-time">1:15 PM</span><span>Academic Lesson 4 (45 min) — English Literature</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Thursday — Young Explorers -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Thursday — Young Explorers</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 5–7</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gentle mind and body exercises, guided play, gardening outside (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:00 AM</span><span>Academic Lesson 1 (30 min) — Math</span></div>
              <div class="schedule-row"><span class="schedule-time">10:30 AM</span><span>Rest and play outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (30 min) — Reading, Writing &amp; Public Speaking</span></div>
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Board games (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Lunch and free play (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (30 min) — Chemistry (T1) · Physics (T2) · Biology (T3) · Environmental Science (T4)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:00 PM</span><span>Rest and play (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:20 PM</span><span>Academic Lesson 4 (30 min) — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">1:50 PM</span><span>Clean up and closing circle (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Thursday — Curious Learners -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Thursday — Curious Learners</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 8–10</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gardening and gentle exercise outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:00 AM</span><span>Academic Lesson 1 (45 min) — Civics/Government Studies (T1–T2) · History (T3–T4)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:45 AM</span><span>Rest (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (45 min) — Critical Thinking (T1–T2) · Geography (T3–T4)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Lunch and free play (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (45 min) — Creative Writing (T1–T2) · Eastern &amp; Western Philosophy (T3–T4)</span></div>
