---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionNav from '../components/SectionNav.astro';
import CallToAction from '../components/CallToAction.astro';
---

<Layout title="Our Program — Shoreline Scholars" description="The Rooted Learning Program: a nature-oriented, whole-child enrichment program for homeschooled students ages 5–12 in Indialantic, Florida.">
  <Header />
  <SectionNav sections={[
    { label: 'Overview', id: 'overview' },
    { label: 'Curriculum', id: 'curriculum' },
    { label: 'Schedule', id: 'weekly-schedule' },
    { label: 'Daily Schedules', id: 'daily-schedules' },
{ label: 'Field Trips', id: 'field-trips' },
    { label: 'Family Partnership', id: 'family-partnership' },
    { label: 'Admissions', id: 'admissions' },
  ]} />

  <!-- ═══ HERO ═══ -->
  <section class="relative flex items-center justify-center text-center px-6"
    style="padding-top: 12rem; padding-bottom: 6rem; background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="font-heading text-shell-white text-5xl md:text-6xl font-medium mb-4">Our Program</h1>
      <p class="font-body font-light text-shell-white/80 text-lg md:text-xl tracking-wide max-w-xl mx-auto">
        The Rooted Learning Program
      </p>
    </div>
  </section>

  <!-- ═══ OVERVIEW ═══ -->
  <section id="overview" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Overview</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <p class="text-[0.95rem] leading-relaxed mb-6 max-w-3xl mx-auto">
        At Shoreline Scholars, we provide a thoughtfully designed, holistic learning experience that supports both academic growth and whole-child development.
      </p>
      <p class="text-[0.95rem] leading-relaxed mb-6 max-w-3xl mx-auto">
        For families enrolled in our full-time 3-day/week program, all major academic subjects are covered and provided through engaging, thoughtfully created workbooks. The Rooted Learning Program runs Wednesday through Friday during both the Fall semester (August through December) and Spring semester (January through May). Families may enroll in a 1-day, 2-day, or 3-day weekly schedule.
      </p>
      <p class="text-[0.95rem] leading-relaxed max-w-3xl mx-auto">
        The program is led by a team whose credentials include a doctorate-level Licensed Mental Health Counselor and 20 years of classroom teaching experience.
      </p>
    </div>
  </section>

  <!-- ═══ CURRICULUM ═══ -->
  <section id="curriculum" class="py-24 md:py-32" style="background: rgba(232, 213, 183, 0.15);">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Curriculum and Academic Scope</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <p class="text-[0.95rem] leading-relaxed mb-10 max-w-3xl mx-auto">
        The Rooted Learning Program delivers comprehensive academic instruction across all major subject areas. Students enrolled in the full-time 3-day schedule receive instruction in the following disciplines:
      </p>

      <div class="max-w-3xl mx-auto" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <!-- Year-Round -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Both Fall and Spring Semesters</h3>
          <p class="font-body text-driftwood text-xs uppercase tracking-wider mb-3">August through May</p>
          <ul class="subject-list">
            <li>English Literature</li>
            <li>Art</li>
            <li>Science (Chemistry/Physics, Animal Science, Marine Biology, Plant Studies, and Oceanography)</li>
          </ul>
        </div>

        <!-- Fall Semester -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Fall Semester</h3>
          <p class="font-body text-driftwood text-xs uppercase tracking-wider mb-3">August through December</p>
          <ul class="subject-list">
            <li>Civics and Government Studies</li>
            <li>Creative Writing</li>
            <li>Critical Thinking</li>
          </ul>
        </div>

        <!-- Spring Semester -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Spring Semester</h3>
          <p class="font-body text-driftwood text-xs uppercase tracking-wider mb-3">January through May</p>
          <ul class="subject-list">
            <li>History</li>
            <li>Geography</li>
            <li>Eastern and Western Philosophy</li>
          </ul>
        </div>

        <!-- Enrichment & Real-World Learning -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Enriched, Real-World Learning</h3>
          <p class="text-[0.95rem] leading-relaxed mb-4">
            In addition to these foundational subjects, Shoreline Scholars offers enriched, real-world learning opportunities that extend beyond traditional academics. Students are exposed to and engaged in:
          </p>
          <ul class="subject-list">
            <li>Daily Reading and Writing Concepts</li>
            <li>Mathematics Integration</li>
            <li>Entrepreneurship (Business/Economic Principles and Financial Literacy)</li>
            <li>Horticulture</li>
            <li>Carpentry</li>
          </ul>
          <p class="text-[0.92rem] leading-relaxed mt-4 text-driftwood italic">
            These areas are introduced in age-appropriate, hands-on ways that encourage critical thinking, creativity, and practical life skills. Students will have opportunities to participate in entrepreneurial events, designing and selling handmade products.
          </p>
        </div>
      </div>

      <!-- Instructional Delivery -->
      <div class="max-w-3xl mx-auto mt-12">
        <h3 class="font-heading text-deep-sea text-xl mb-4">Instructional Delivery</h3>
        <p class="text-[0.95rem] leading-relaxed">
          Academic content is delivered through thoughtfully created workbooks and guided instruction. The program serves two age groups with differentiated schedules: younger students (ages 5–7) receive shorter lesson blocks with more structured play and movement, while older students (ages 8–12) engage in longer instructional periods with self-directed project time. Both groups benefit from daily outdoor learning, including gardening, gentle exercise, and coastal exploration.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ SCHEDULE ═══ -->
  <section id="weekly-schedule" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Program Schedule</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="max-w-3xl mx-auto mb-10">
        <p class="text-[0.95rem] leading-relaxed mb-4">
          <strong class="text-deep-sea">Wednesday and Thursday:</strong> 9:30 AM to 2:00 PM<br />
          <span class="text-driftwood text-[0.88rem]">St. Sebastian by-the-Sea, 2010 Oak St, Melbourne Beach, FL</span>
        </p>
        <p class="text-[0.95rem] leading-relaxed">
          <strong class="text-deep-sea">Friday (Nature Day):</strong> 9:30 AM to 2:00 PM<br />
          <span class="text-driftwood text-[0.88rem]">Paradise Beach (August and September, April and May) &middot; Orlando Park (October through March)</span>
        </p>
      </div>

      <div class="max-w-3xl mx-auto" style="display: flex; flex-direction: column; gap: 1.5rem;">
        <div class="schedule-card">
          <div class="schedule-card-header">
            <h3 class="font-heading text-deep-sea text-xl">Wednesday</h3>
            <div class="schedule-meta">
              <span class="age-badge">Ages 5–12</span>
              <span class="time-badge">9:30 AM – 2:00 PM</span>
            </div>
          </div>
          <p class="text-[0.95rem] leading-relaxed mt-3">
            Core academics (English Literature, Art, Chemistry and Physics) with entrepreneurship and self-directed project time. Younger students cover Math, Reading/Writing & Public Speaking, Science, and Art.
          </p>
        </div>

        <div class="schedule-card">
          <div class="schedule-card-header">
            <h3 class="font-heading text-deep-sea text-xl">Thursday</h3>
            <div class="schedule-meta">
              <span class="age-badge">Ages 5–12</span>
              <span class="time-badge">9:30 AM – 2:00 PM</span>
            </div>
          </div>
          <p class="text-[0.95rem] leading-relaxed mt-3">
            Semester-specific subjects (Civics/History, Critical Thinking/Geography, Creative Writing/Philosophy) with entrepreneurship and self-directed project time. Younger students follow a parallel structure with the same enrichment integrated.
          </p>
        </div>

        <div class="schedule-card">
          <div class="schedule-card-header">
            <h3 class="font-heading text-deep-sea text-xl">Friday <span class="font-body text-driftwood text-xs uppercase tracking-wider">&mdash; Nature Day</span></h3>
            <div class="schedule-meta">
              <span class="age-badge">All Ages 5–12</span>
              <span class="time-badge">9:30 AM – 2:00 PM</span>
            </div>
          </div>
          <p class="text-[0.95rem] leading-relaxed mt-3">
            All ages come together for nature-focused science instruction. <strong class="text-deep-sea">Ocean Lab</strong> (August–September, April–May) at Paradise Beach covers Oceanography and Marine Biology. <strong class="text-deep-sea">Park Lab</strong> (October–March) at Orlando Park covers Animal Science and Plant Studies.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DAILY SCHEDULES ═══ -->
  <section id="daily-schedules" class="py-24 md:py-32" style="background: rgba(232, 213, 183, 0.15);">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Detailed Daily Schedules</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="max-w-3xl mx-auto" style="display: flex; flex-direction: column; gap: 1.25rem;">

        <!-- Wednesday — Older Kids -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Wednesday — Older Kids</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 8–12</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gardening and gentle exercise outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:10 AM</span><span>Academic Lesson 1 (45 min) — English Literature</span></div>
              <div class="schedule-row"><span class="schedule-time">10:55 AM</span><span>Rest (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:05 AM</span><span>Academic Lesson 2 (45 min) — Chemistry and Physics</span></div>
              <div class="schedule-row"><span class="schedule-time">11:50 AM</span><span>Lunch (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:05 PM</span><span>Go for a walk and explore (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:20 PM</span><span>Academic Lesson 3 (45 min) — outside — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">1:05 PM</span><span>Entrepreneurship / Self-projects with guidance / Individual tutoring (55 min) — outside optional with supervision</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Wednesday — Younger Kids -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Wednesday — Younger Kids</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 5–7</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gentle mind and body exercises, guided play, and gardening outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:10 AM</span><span>Academic Lesson 1 (30 min) — Math</span></div>
              <div class="schedule-row"><span class="schedule-time">10:40 AM</span><span>Rest and play outside (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (30 min) — Reading, Writing & Public Speaking</span></div>
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Lunch (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Take a walk, play, and gardening (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (30 min) — Science with hands-on projects</span></div>
              <div class="schedule-row"><span class="schedule-time">1:00 PM</span><span>Rest and play (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:20 PM</span><span>Academic Lesson 4 (30 min) — outside — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">1:50 PM</span><span>Clean up and closing circle (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Thursday — Older Kids -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Thursday — Older Kids</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 8–12</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gardening and gentle exercise outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:10 AM</span><span>Academic Lesson 1 (45 min) — Civics/Government Studies (Fall) · History (Spring)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:55 AM</span><span>Rest (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:05 AM</span><span>Academic Lesson 2 (45 min) — Critical Thinking (Fall) · Geography (Spring)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:50 AM</span><span>Lunch at the center (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:05 PM</span><span>Go for a walk and explore (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:20 PM</span><span>Academic Lesson 3 (45 min) — outside — Creative Writing (Fall) · Eastern and Western Philosophy (Spring)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:05 PM</span><span>Entrepreneurship / Self-projects with guidance / Individual tutoring (55 min) — outside optional with supervision</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Thursday — Younger Kids -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Thursday — Younger Kids</span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">Ages 5–7</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meeting and check-in with advisor (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Gentle mind and body exercises, guided play, and gardening outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:10 AM</span><span>Academic Lesson 1 (30 min) — Math</span></div>
              <div class="schedule-row"><span class="schedule-time">10:40 AM</span><span>Rest and play outside (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Academic Lesson 2 (30 min) — Reading, Writing & Public Speaking</span></div>
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Lunch (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Take a walk, play, and gardening (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Academic Lesson 3 (30 min) — Science with hands-on projects</span></div>
              <div class="schedule-row"><span class="schedule-time">1:00 PM</span><span>Rest and play (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:20 PM</span><span>Academic Lesson 4 (30 min) — outside — Art</span></div>
              <div class="schedule-row"><span class="schedule-time">1:50 PM</span><span>Clean up and closing circle (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Friday — Ocean Lab -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Friday — Ocean Lab <span class="font-body text-driftwood text-xs uppercase tracking-wider">&mdash; Paradise Beach</span></span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">All Ages 5–12</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
                <span class="season-badge">Aug–Sep, Apr–May</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <p class="text-[0.88rem] text-sunrise font-medium mb-3">Drop-off is not available for Ocean Lab days.</p>
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meet and greet (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Ocean exploration (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:10 AM</span><span>Academic Lesson 1 (30 min) — Oceanography</span></div>
              <div class="schedule-row"><span class="schedule-time">10:40 AM</span><span>Rest (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:55 AM</span><span>Academic Lesson 2 (30 min) — Marine Biology</span></div>
              <div class="schedule-row"><span class="schedule-time">11:25 AM</span><span>Lunch (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:40 AM</span><span>Walk and explore (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:55 AM</span><span>Group activities and games (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:25 PM</span><span>Art (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:55 PM</span><span>Journaling and presentation, self-projects with guidance (1 hr)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

        <!-- Friday — Park Lab -->
        <details class="accordion-panel">
          <summary class="accordion-summary">
            <div>
              <span class="font-heading text-deep-sea text-lg font-semibold">Friday — Park Lab <span class="font-body text-driftwood text-xs uppercase tracking-wider">&mdash; Orlando Park</span></span>
              <span class="schedule-meta" style="margin-top: 0.25rem;">
                <span class="age-badge">All Ages 5–12</span>
                <span class="time-badge">9:30 AM – 2:00 PM</span>
                <span class="season-badge">Oct–Mar</span>
              </span>
            </div>
            <svg class="accordion-chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="accordion-content">
            <p class="text-[0.88rem] text-driftwood font-medium mb-3">Drop-off optional for Park Lab days.</p>
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:30 AM</span><span>Morning meet and greet (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Nature exploration (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:10 AM</span><span>Academic Lesson 1 (30 min) — Animal Science</span></div>
              <div class="schedule-row"><span class="schedule-time">10:40 AM</span><span>Rest (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:55 AM</span><span>Academic Lesson 2 (30 min) — outside — Plant Studies</span></div>
              <div class="schedule-row"><span class="schedule-time">11:25 AM</span><span>Lunch (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:40 AM</span><span>Walk and explore (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:55 AM</span><span>Group activities and games (20 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:15 PM</span><span>Older kids read to younger kids (15 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Art (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:00 PM</span><span>Journaling and presentation, self-projects with guidance (1 hr)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal</span></div>
            </div>
          </div>
        </details>

      </div>
    </div>
  </section>

  <!-- ═══ FIELD TRIPS ═══ -->
