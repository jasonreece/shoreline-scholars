---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionNav from '../components/SectionNav.astro';
import CallToAction from '../components/CallToAction.astro';
---

<Layout>
  <Header />
  <SectionNav sections={[
    { label: 'About', id: 'about' },
    { label: 'Our Story', id: 'our-story' },
    { label: 'Guiding Principles', id: 'guiding-principles' },
    { label: 'Founders', id: 'team' },
    { label: 'Our Team', id: 'our-team' },
    { label: 'Contact', id: 'get-involved' },
  ]} />

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-screen flex items-center justify-center text-center px-6 pt-20"
    style="background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <!-- Subtle texture overlay -->
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <img src="/logo-white.png" alt="" class="h-20 md:h-28 w-auto mx-auto" />
      <h1 class="font-heading text-shell-white text-5xl md:text-7xl font-medium mb-6 leading-tight">
        Shoreline Scholars
      </h1>
      <p class="font-body font-normal text-shell-white/90 text-lg md:text-xl tracking-wide mb-6 max-w-xl mx-auto">
        Where curiosity meets the coastline
      </p>
      <p class="font-body text-shell-white/70 text-base md:text-lg leading-relaxed mb-10 max-w-2xl mx-auto text-balance">
        A nonprofit beachside learning community for children ages 5–12.
        Enrichment programs for homeschool families, after-school adventures for everyone.
      </p>
      <Button variant="secondary" href="#about">
        <span class="text-shell-white border-shell-white hover:bg-shell-white/10">Learn More</span>
      </Button>
    </div>

  </section>

  <!-- ═══ ABOUT ═══ -->
  <section id="about" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Learning Comes to Life</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto mb-8"></div>
        <p class="text-lg leading-relaxed max-w-2xl mx-auto">
          A relational, hands-on learning community designed to support the whole-child
          development of homeschooled students in Indialantic, Florida. Our approach
          integrates nature-based exploration, academic enrichment, and relationship-centered
          care in a beachside setting.
        </p>
      </div>

      <!-- Brand Pillars -->
      <div class="grid md:grid-cols-2 gap-8 mt-16">
        <div class="bg-warm-sand/20 rounded-xl p-8">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Grounded Expertise</h3>
          <p class="text-sm leading-relaxed">
            Rachel's doctorate and Chi's 20 years of teaching — the brand carries
            quiet authority. Clinical knowledge meets real-world classroom wisdom.
          </p>
        </div>
        <div class="bg-warm-sand/20 rounded-xl p-8">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Nature as Classroom</h3>
          <p class="text-sm leading-relaxed">
            Beach, ocean, sand, sunlight — learning happens outdoors, in the real
            world. The Indialantic shoreline is both our campus and our curriculum.
          </p>
        </div>
        <div class="bg-warm-sand/20 rounded-xl p-8">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Whole-Child Care</h3>
          <p class="text-sm leading-relaxed">
            Emotionally grounded, relationship-centered, social-emotional — not just academics.
            We nurture the complete child: mind, body, and heart.
          </p>
        </div>
        <div class="bg-warm-sand/20 rounded-xl p-8">
          <h3 class="font-heading text-deep-sea text-xl mb-3">Community</h3>
          <p class="text-sm leading-relaxed">
            Homeschool families supporting each other — this is a village, not a
            service. Connection is at the heart of everything we do.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OUR STORY ═══ -->
  <section id="our-story" class="py-20" style="background-color: #E8D5B7;">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-deep-sea mb-6">Our Story</h2>
      <div class="w-12 h-0.5 bg-sea-glass mx-auto mb-12"></div>

      <p class="font-body text-base leading-relaxed mb-6" style="color: #4A5859;">
        When Rachel and Chi met, something clicked immediately — a shared belief that childhood
        is a sacred season, and that children deserve more than desks, screens, and standardized tests.
      </p>

      <p class="font-body text-base leading-relaxed mb-6" style="color: #4A5859;">
        Both saw the same thing in the traditional school system: children spending long hours
        indoors with little space to explore, imagine, move, or build deep relationships with mentors
        and peers. Both believed that children learn best through curiosity, connection, play, nature,
        and meaningful guidance. And both wanted to build something better.
      </p>

      <p class="font-heading italic text-2xl md:text-3xl text-deep-sea mt-10 mb-10 leading-snug">
        Shoreline Scholars was born from that shared conviction.
      </p>

      <p class="font-body text-base leading-relaxed mb-6" style="color: #4A5859;">
        We created a learning environment where children experience the richness of childhood while
        developing the skills and character they'll need for the future — where education happens not
        behind walls, but through exploration of the shoreline, hands-on science, creative expression,
        and collaborative discovery.
      </p>

      <p class="font-body text-base leading-relaxed mb-6" style="color: #4A5859;">
        At Shoreline Scholars, education is about forming the whole child: emotional intelligence and
        healthy relationships, curiosity and a love of learning, connection with nature and the real
        world, creativity and critical thinking, character development and personal responsibility.
      </p>

      <p class="font-body text-base leading-relaxed mb-6" style="color: #4A5859;">
        Our hope is that the children who grow here will become not only strong learners, but
        compassionate leaders, thoughtful citizens, and resilient human beings.
      </p>

      <p class="font-heading italic text-xl md:text-2xl text-deep-sea mt-10 mb-6 leading-snug">
        Because how we raise children today shapes the world they will lead tomorrow.
      </p>

      <p class="font-body text-sm tracking-wide" style="color: #B8977E;">
        — Rachel Glover &amp; Chi Reece, Founders
      </p>
    </div>
  </section>

  <!-- ═══ GUIDING PRINCIPLES ═══ -->
  <section id="guiding-principles" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-heading text-deep-sea mb-6">Guiding Principles</h2>
      <div class="w-12 h-0.5 bg-sea-glass mx-auto mb-12"></div>

      <p class="font-body text-base leading-relaxed mb-6" style="color: #4A5859;">
        Shoreline Scholars is guided by principles of stewardship, character development,
        curiosity, and community. While the program itself is educational and not a religious
        instruction program, its leadership is shaped by a Christian worldview that values
        humility, responsibility, service to others, and care for creation.
      </p>

      <p class="font-body text-base leading-relaxed" style="color: #4A5859;">
        Our goal is to provide a supportive environment where children can grow intellectually,
        socially, and emotionally while exploring the world around them.
      </p>
    </div>
  </section>

  <!-- ═══ TEAM ═══ -->
  <section id="team" class="py-24 md:py-32">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Meet the Founders</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-10">
        <!-- Rachel -->
        <div class="bg-warm-sand/40 rounded-2xl p-10 text-center">
          <img src="/headshot-rachel.jpeg" alt="Rachel Glover" class="w-28 h-28 rounded-full object-cover mx-auto mb-6" />
          <h3 class="font-heading text-deep-sea text-2xl mb-1">Rachel Glover</h3>
          <p class="text-shoreline font-body font-medium text-sm uppercase tracking-wider mb-4">
            Founder &amp; Executive Director
          </p>
          <div class="w-10 h-px bg-driftwood mx-auto mb-4"></div>
          <p class="text-sm leading-relaxed mb-3">
            Rachel Glover is a Christian counselor whose work integrates faith-informed
            values, attachment science, and whole-child development. She is a Nationally
            Certified Counselor (NCC) and Licensed Mental Health Counselor (LMHC) with
            a research focus on developmental psychology.
          </p>
          <p class="text-sm leading-relaxed mb-3">
            She founded Shoreline Scholars to create a learning community where children
            are known, valued, and supported — not just academically, but socially,
            emotionally, and spiritually. Her approach is rooted in attachment science,
            relational health, and the conviction that children flourish when they feel
            safe, connected, and free to be curious.
          </p>
          <p class="text-sm leading-relaxed mb-3">
            With specialized experience in premarital, marriage, and family counseling,
            Rachel brings a deep understanding of how relationships shape development.
            Through Shoreline Scholars, she integrates experiential learning, real-world
            skill development, and strong family partnership in a nature-based setting.
          </p>
          <p class="text-sm leading-relaxed italic mt-4" style="color: #B8977E;">
            While Rachel's professional background informs her passion for supporting healthy
            child development, Shoreline Scholars is an educational enrichment program and does
            not provide counseling, therapy, or mental health services.
          </p>
        </div>

        <!-- Chi -->
        <div class="bg-warm-sand/40 rounded-2xl p-10 text-center">
          <img src="/headshot-chi.jpeg" alt="Chi Reece" class="w-28 h-28 rounded-full object-cover mx-auto mb-6" />
          <h3 class="font-heading text-deep-sea text-2xl mb-1">Chi Reece</h3>
          <p class="text-shoreline font-body font-medium text-sm uppercase tracking-wider mb-4">
            Founder &amp; Program Director
          </p>
          <div class="w-10 h-px bg-driftwood mx-auto mb-4"></div>
          <p class="text-sm leading-relaxed mb-3">
            Chi is a co-founder of Shoreline Scholars with a bachelor's degree in
            Chemistry and Mathematics from Austin Peay State University. Originally
            from Hong Kong, she came to the United States as an exchange student at
            15 and graduated high school at 16. She is also a certified yoga
            instructor, bringing a mind-body approach to her work with children.
          </p>
          <p class="text-sm leading-relaxed mb-3">
            With 20 years of experience teaching math, science, and yoga at Ben
            Franklin Academy — a private micro school in Atlanta specializing in
            individualized mastery programs — Chi brings deep expertise in one-on-one
            instruction and helping students reach their learning goals at their own pace.
          </p>
          <p class="text-sm leading-relaxed mb-3">
            As a homeschooling mother, Chi is passionate about protecting the curiosity,
            creativity, and joyful spirit that children naturally bring to learning. Her
            own experience growing up in an intensive educational system that prioritized
            conformity over creativity gives her a unique perspective — one that honors
            discipline and academic rigor while fiercely protecting a child's sense of self.
          </p>
          <p class="text-sm leading-relaxed">
            Through Shoreline Scholars, Chi brings together her background in science and
            mathematics, her years of individualized instruction, and her belief that
            children innately want to learn — nurturing kids in a safe, holistic,
            nature-oriented environment where they can thrive both as learners and as
            individuals.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OUR TEAM ═══ -->
  <section id="our-team" class="py-24 md:py-32" style="background: rgba(232, 213, 183, 0.15);">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Our Team</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4" style="gap: 2.5rem;">
        <button class="team-tile" data-team="isabel" type="button">
          <img src="/headshot-isabel.jpg" alt="Isabel Hunt" class="team-tile-photo" />
          <h3 class="team-tile-name">Isabel Hunt</h3>
          <p class="team-tile-title">Administrative Assistant</p>
        </button>

        <button class="team-tile" data-team="stacey" type="button">
          <img src="/headshot-stacey.jpg" alt="Stacey Marmolejo" class="team-tile-photo" />
          <h3 class="team-tile-name">Stacey Marmolejo</h3>
          <p class="team-tile-title">Educator</p>
        </button>

        <button class="team-tile" data-team="emily" type="button">
          <img src="/headshot-emily.png" alt="Emily Warner" class="team-tile-photo" />
          <h3 class="team-tile-name">Emily Warner</h3>
          <p class="team-tile-title">Educator</p>
        </button>

        <button class="team-tile" data-team="jennifer" type="button">
          <img src="/headshot-jennifer.jpg" alt="Jennifer Condry" class="team-tile-photo" />
          <h3 class="team-tile-name">Jennifer Condry</h3>
          <p class="team-tile-title">Educator</p>
        </button>

        <button class="team-tile" data-team="john" type="button">
          <img src="/images/events/john-brady.jpg" alt="John Brady" class="team-tile-photo" />
          <h3 class="team-tile-name">John Brady</h3>
          <p class="team-tile-title">Guest Educator</p>
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ TEAM BIO MODALS ═══ -->
  <div id="team-modal-backdrop" class="team-modal-backdrop" hidden>
    <div class="team-modal" role="dialog" aria-modal="true" aria-labelledby="team-modal-name">
      <button class="team-modal-close" aria-label="Close" type="button">&times;</button>
      <img id="team-modal-photo" src="" alt="" class="team-modal-photo" />
      <h3 id="team-modal-name" class="team-modal-name"></h3>
      <p id="team-modal-title" class="team-modal-title"></p>
      <div class="w-10 h-px bg-driftwood mx-auto mb-6"></div>
      <div id="team-modal-bio" class="team-modal-bio"></div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var teamData = {
        emily: {
          name: 'Emily Warner',
          title: 'Educator',
          photo: '/headshot-emily.png',
          bio: '<p>Emily brings a storyteller\u2019s eye to everything she does. With a degree in English and a minor in World Cultures and Literature from Kent State, plus seven years of professional writing across industries as wide-ranging as travel, local journalism, and wellness, she knows how to find the thread that makes ideas come alive.</p><p>She\u2019s also a personal trainer \u2014 which means she understands firsthand that real growth, whether physical or intellectual, happens through consistency, encouragement, and showing up.</p><p>At Shoreline Scholars, Emily is here to show students that literature isn\u2019t just something you read \u2014 it\u2019s how you understand the world. She\u2019ll bring books to life, build critical thinkers, and remind every young reader that their own story matters too.</p>'
        },
        stacey: {
          name: 'Stacey Marmolejo',
          title: 'Educator',
          photo: '/headshot-stacey.jpg',
          bio: '<p>Stacey Marmolejo is a published author, writing coach, and veteran educator with 40 years of experience in the classroom \u2014 and a career that proves what happens when someone genuinely believes in the people in front of them.</p><p>She\u2019s built School of Rock franchises, produced large-scale live events, and written six books, including the Insider\u2019s Guide to the Space Coast. She\u2019s the kind of person who shows up for a community and leaves it measurably better.</p><p>In Shoreline Scholars\u2019 Creative Writing Lab, Stacey brings that same energy to young writers. Her workshops blend writing craft with visual art, helping students find their voice, trust their ideas, and discover the joy of putting stories on the page. She\u2019s not here to teach rules \u2014 she\u2019s here to help kids fall in love with storytelling.</p>'
        },
        john: {
          name: 'John Brady',
          title: 'Guest Educator',
          photo: '/images/events/john-brady.jpg',
          bio: '<p>John N. Brady is a retired US Coast Guard Senior Chief Boatswain\u2019s Mate and former law enforcement officer whose career spans military service, criminal investigation, and maritime security at Port Canaveral.</p><p>A recipient of the VCSO Medal of Valor and Purple Heart, John holds a B.S. in Criminal Justice from University of Maryland University College. Since settling in Indialantic in 2020, he has served on the Town\u2019s Code Enforcement Board and, since 2024, on the Indialantic Town Council.</p><p>Through Shoreline Scholars\u2019 Civics in Action program, John brings local government to life for students and families \u2014 opening the doors to Town Hall, the police station, and the fire station so kids can see civics firsthand.</p>'
        },
        isabel: {
          name: 'Isabel Hunt',
          title: 'Administrative Assistant',
          photo: '/headshot-isabel.jpg',
          bio: '<p>Isabel brings more than 15 years of experience in caregiving, travel, and client services to Shoreline Scholars \u2014 and a deep belief that the best things in life happen outside.</p><p>Before joining the team, Isabel spent a decade as a certified nursing assistant supporting seniors with compassion and dignity, then brought that same people-first warmth to the travel industry. Her career began with an internship at the Court of Appeals, where she built a foundation in responsibility, empathy, and service that has shaped every role since. She holds a Bachelor of Arts in International Studies.</p><p>At Shoreline Scholars, Isabel keeps the day-to-day running smoothly \u2014 family communication, enrollment, scheduling, and program logistics \u2014 so that instructors and students can focus on what matters most. Her background in caregiving gives her a natural sensitivity to the needs of both children and parents, and her global experiences \u2014 from South Korea and Japan to Italy, France, and across Southeast Asia \u2014 have given her a rich appreciation for curiosity and learning through experience.</p><p>Married to a proud Kiwi, and mom to her four-year-old daughter Eloise, Isabel\u2019s favorite classroom has always been the beach \u2014 which is exactly where you\u2019ll find her, Eloise, and their dog Coco when the day is done.</p>'
        },
        jennifer: {
          name: 'Jennifer Condry',
          title: 'Educator',
          photo: '/headshot-jennifer.jpg',
          bio: '<p>Jennifer is a certified educator with more than a decade of experience helping young readers and learners find their confidence. She believes children learn best when they feel safe, challenged, and genuinely encouraged \u2014 and she brings that belief into everything she does.</p><p>Her approach blends strong academic foundations with hands-on, inventive play \u2014 sparking curiosity while tailoring instruction to each child\u2019s unique needs and interests. She holds a bachelor\u2019s degree in Pre-K/Primary Education and a master\u2019s degree in Reading Education (K\u201312) from Barry University, and has worked with students ranging from early childhood through high school.</p><p>At Shoreline Scholars, Jennifer is focused on empowering young learners to become confident readers and critical thinkers within a nurturing, nature-oriented environment. When she\u2019s not in the classroom, you\u2019ll find her at the beach with her family or hosting a local Bible study in Brevard County, where she and her husband serve as ministers.</p>'
        }
      };

      var backdrop = document.getElementById('team-modal-backdrop');
      var modal = backdrop.querySelector('.team-modal');
      var closeBtn = backdrop.querySelector('.team-modal-close');
      var photoEl = document.getElementById('team-modal-photo');
      var nameEl = document.getElementById('team-modal-name');
      var titleEl = document.getElementById('team-modal-title');
      var bioEl = document.getElementById('team-modal-bio');
      var lastFocused = null;

      function openModal(key) {
        var data = teamData[key];
        if (!data) return;
        lastFocused = document.activeElement;
        photoEl.src = data.photo;
        photoEl.alt = data.name;
        nameEl.textContent = data.name;
        titleEl.textContent = data.title;
        bioEl.innerHTML = data.bio;
        backdrop.hidden = false;
        document.body.style.overflowY = 'scroll';
        document.body.style.position = 'fixed';
        document.body.style.width = '100%';
        document.body.style.top = '-' + window.scrollY + 'px';
        backdrop.dataset.scrollY = window.scrollY;
        requestAnimationFrame(function () {
          backdrop.classList.add('team-modal-backdrop--visible');
        });
        closeBtn.focus();
      }

      function closeModal() {
        backdrop.classList.remove('team-modal-backdrop--visible');
        var scrollY = backdrop.dataset.scrollY || '0';
        document.body.style.position = '';
        document.body.style.width = '';
        document.body.style.top = '';
        document.body.style.overflowY = '';
        window.scrollTo(0, parseInt(scrollY, 10));
        setTimeout(function () {
          backdrop.hidden = true;
        }, 250);
        if (lastFocused) lastFocused.focus();
      }

      document.querySelectorAll('.team-tile').forEach(function (tile) {
        tile.addEventListener('click', function () {
          openModal(tile.getAttribute('data-team'));
        });
      });

      closeBtn.addEventListener('click', closeModal);

      backdrop.addEventListener('click', function (e) {
        if (e.target === backdrop) closeModal();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !backdrop.hidden) closeModal();
        if (e.key === 'Tab' && !backdrop.hidden) {
          var focusable = modal.querySelectorAll('button, [href], [tabindex]:not([tabindex="-1"])');
          var first = focusable[0];
          var last = focusable[focusable.length - 1];
          if (e.shiftKey) {
            if (document.activeElement === first) { e.preventDefault(); last.focus(); }
          } else {
            if (document.activeElement === last) { e.preventDefault(); first.focus(); }
          }
        }
      });
    })();
  </script>

  <CallToAction
    heading="Ready to explore?"
    description="We'd love to hear from you. Whether you're curious about our program, want to visit, or are ready to enroll — reach out and let's start the conversation."

  />

  <Footer />
</Layout>

<style>
  /* Hero button override for the outlined-on-dark style */
  section:first-of-type :global(a) {
    border-color: rgba(250, 247, 242, 0.6);
    color: #FAF7F2;
    background: transparent;
  }
  section:first-of-type :global(a:hover) {
    background: rgba(250, 247, 242, 0.12);
    border-color: #FAF7F2;
    color: #FAF7F2;
  }
  section:first-of-type :global(a span) {
    color: inherit;
  }

  /* ─── Team Tiles ─── */
  .team-tile {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: none;
    border: none;
    padding: 1.5rem 1rem;
    cursor: pointer;
    border-radius: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .team-tile:hover {
    transform: scale(1.04);
    box-shadow: 0 4px 20px rgba(27, 79, 82, 0.08);
  }
  .team-tile:focus-visible {
    outline: 2px solid #5AAFA6;
    outline-offset: 4px;
    border-radius: 1rem;
  }
  .team-tile-photo {
    width: 7rem;
    height: 7rem;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 1rem;
  }
  .team-tile-name {
    font-family: var(--font-heading);
    color: #1B4F52;
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }
  .team-tile-title {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2A7F62;
  }

  /* ─── Team Modal ─── */
  .team-modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(27, 79, 82, 0);
    transition: background 0.25s ease;
    padding: 1.5rem;
  }
  .team-modal-backdrop--visible {
    background: rgba(27, 79, 82, 0.55);
  }
  .team-modal {
    position: relative;
    background: #FAF7F2;
    border-radius: 1.25rem;
    max-width: 600px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    padding: 2.5rem 2.5rem 2rem;
    text-align: center;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.25s ease, transform 0.25s ease;
    box-shadow: 0 8px 40px rgba(27, 79, 82, 0.15);
  }
  .team-modal-backdrop--visible .team-modal {
    opacity: 1;
    transform: scale(1);
  }
  .team-modal-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.75rem;
    line-height: 1;
    color: #B8977E;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    transition: color 0.15s ease;
  }
  .team-modal-close:hover {
    color: #1B4F52;
  }
  .team-modal-close:focus-visible {
    outline: 2px solid #5AAFA6;
    outline-offset: 2px;
