---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import SectionNav from '../components/SectionNav.astro';
import CallToAction from '../components/CallToAction.astro';
import Ecosystem from '../components/Ecosystem.jsx';
---

<Layout title="Our Vision — Shoreline Scholars" description="A week in the life of a Shoreline Scholar. Discover our integrated educational ecosystem blending academics, nature, creativity, and real-world skills.">
  <Header />
  <SectionNav sections={[
    { label: 'Overview', id: 'hero-top' },
    { label: 'Curriculum', id: 'curriculum' },
    { label: 'Weekly Schedule', id: 'weekly-schedule' },
    { label: 'Daily Schedules', id: 'daily-schedules' },
    { label: 'After School', id: 'after-school' },
    { label: 'Ecosystem', id: 'ecosystem' },
  ]} />

  <!-- ═══ HERO ═══ -->
  <section id="hero-top" class="relative flex items-center justify-center text-center px-6"
    style="padding-top: 12rem; padding-bottom: 6rem; background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 45%, #5AAFA6 100%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0%, transparent 50%);">
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <h1 class="font-heading text-shell-white text-5xl md:text-6xl font-medium mb-4">Our Vision</h1>
      <p class="font-body font-light text-shell-white/80 text-lg md:text-xl tracking-wide max-w-xl mx-auto">
        A week in the life of a Shoreline Scholar
      </p>
    </div>
  </section>

  <!-- ═══ INTRODUCTION ═══ -->
  <section id="overview" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-[0.95rem] leading-relaxed">
        Shoreline Scholars is building a learning community where academics, nature,
        creativity, and real-world skills work together — not in isolation. Our educational
        ecosystem integrates eight pillars: academics, outdoor learning, creative arts,
        social-emotional growth, entrepreneurship, trade skills, financial literacy, and
        life skills. Every day touches multiple pillars. Every week tells a complete story.
      </p>
    </div>
  </section>

  <!-- ═══ WHAT WE TEACH ═══ -->
  <section id="curriculum" class="bg-shell-white py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">What We Teach</h2>
        <div class="w-12 h-0.5 bg-sea-glass mx-auto mb-10"></div>
        <p class="text-[0.95rem] leading-relaxed max-w-3xl mx-auto">
          Our curriculum is built around the belief that real education connects subjects to each
          other and to the world outside. Every course is taught through hands-on projects, outdoor
          exploration, and collaborative discovery — not textbooks and tests.
        </p>
      </div>

      <div class="grid md:grid-cols-2" style="gap: 1.5rem;">
        <!-- Ages 9–12 -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-[1.5rem] font-semibold mb-6">Ages 9–12 (4th–8th Grade)</h3>

          <div class="curriculum-group">
            <span class="curriculum-label">Language & Ideas</span>
            <p class="curriculum-courses">Literature, Critical Thinking, Public Speaking</p>
          </div>

          <div class="curriculum-group">
            <span class="curriculum-label">Science & Nature</span>
            <p class="curriculum-courses">Animal Science & Marine Biology, Horticulture, Food Prep & Nutrition</p>
          </div>

          <div class="curriculum-group">
            <span class="curriculum-label">World & Society</span>
            <p class="curriculum-courses">Government, History, Geography, Art History</p>
          </div>

          <div class="curriculum-group">
            <span class="curriculum-label">Building & Business</span>
            <p class="curriculum-courses">Entrepreneurship, Financial Literacy</p>
          </div>

          <div class="curriculum-group">
            <span class="curriculum-label">Creative Arts</span>
            <p class="curriculum-courses">Art, Music</p>
          </div>

          <p class="curriculum-note">
            Guest speakers and educators join us for occasional workshops in carpentry, sewing, and electrical engineering.
          </p>
        </div>

        <!-- Ages 5–8 -->
        <div class="curriculum-card">
          <h3 class="font-heading text-deep-sea text-[1.5rem] font-semibold mb-6">Ages 5–8 (K–3rd Grade)</h3>

          <div class="curriculum-group">
            <span class="curriculum-label">Core Skills</span>
            <p class="curriculum-courses">Reading, Writing, Math</p>
          </div>

          <div class="curriculum-group">
            <span class="curriculum-label">Expression & Communication</span>
            <p class="curriculum-courses">Public Speaking, Art</p>
          </div>

          <div class="curriculum-group">
            <span class="curriculum-label">Discovery</span>
            <p class="curriculum-courses">Science (hands-on exploration)</p>
          </div>
        </div>
      </div>

      <p class="font-body font-light text-lg leading-relaxed text-center max-w-3xl mx-auto mt-12" style="color: #4A5859;">
        Every subject connects back to our <a href="#ecosystem" class="text-shoreline hover:text-deep-sea transition-colors underline decoration-sea-glass underline-offset-2">eight ecosystem pillars</a>. A horticulture lesson is science,
        nutrition, and life skills in one. An entrepreneurship project is math, public speaking, and
        creative thinking. Nothing is taught in isolation.
      </p>
    </div>
  </section>

  <!-- ═══ A WEEK AT SHORELINE SCHOLARS ═══ -->
  <section id="weekly-schedule" class="bg-warm-sand/15 py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">A Week at Shoreline Scholars</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="flex flex-col gap-8">
        <!-- Monday & Wednesday -->
        <div class="bg-shell-white rounded-2xl p-8 md:p-10">
          <p class="font-body font-medium text-shoreline text-xs uppercase tracking-widest mb-2">Ages 9–12</p>
          <h3 class="font-heading text-deep-sea text-[1.5rem] font-semibold mb-1">Monday &amp; Wednesday</h3>
          <p class="text-driftwood font-body font-medium text-xs tracking-wide mb-6">9:00 AM – 2:00 PM &nbsp;·&nbsp; Full Day Program</p>
          <p class="text-[0.95rem] leading-relaxed">
            The day begins outdoors with gardening and gentle movement before shifting into
            focused academic blocks — math, science, reading and writing, and geography. After
            lunch outside, the afternoon opens into self-directed projects and individual
            tutoring, where students pursue their own curiosities with guidance from their
            advisor. The day closes with a community meeting.
          </p>
        </div>

        <!-- Tuesday & Thursday -->
        <div class="bg-shell-white rounded-2xl p-8 md:p-10">
          <p class="font-body font-medium text-shoreline text-xs uppercase tracking-widest mb-2">Ages 5–8</p>
          <h3 class="font-heading text-deep-sea text-[1.5rem] font-semibold mb-1">Tuesday &amp; Thursday</h3>
          <p class="text-driftwood font-body font-medium text-xs tracking-wide mb-6">Morning: 9:00–11:30 AM &nbsp;·&nbsp; Afternoon: 11:30 AM–2:00 PM</p>
          <p class="text-[0.95rem] leading-relaxed">
            Two sessions designed for younger learners. Each session blends guided play,
            gentle stretching, hands-on science projects, and early reading and writing — all
            in shorter, age-appropriate blocks that honor how young children learn best.
            Families choose the morning session, the afternoon session, or both.
          </p>
        </div>

        <!-- Friday -->
        <div class="bg-shell-white rounded-2xl p-8 md:p-10">
          <p class="font-body font-medium text-shoreline text-xs uppercase tracking-widest mb-2">All Ages 5–12</p>
          <h3 class="font-heading text-deep-sea text-[1.5rem] font-semibold mb-1">Friday</h3>
          <p class="text-driftwood font-body font-medium text-xs tracking-wide mb-6">9:00 AM – 2:00 PM &nbsp;·&nbsp; Available with 3-day program</p>
          <p class="text-[0.95rem] leading-relaxed">
            Friday is the heartbeat of the week. The morning starts on the beach with surfing
            or somatic movement, followed by community service like beach cleanup. After lunch,
            students return to the center for animal science, entrepreneurship, and collaborative
            time — older kids reading to younger kids, sessions with therapy dogs, and
            self-directed projects. It's the day that ties everything together.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DETAILED SCHEDULES ═══ -->
  <section id="daily-schedules" class="bg-shell-white py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">Detailed Daily Schedules</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <div class="flex flex-col" style="gap: 1.25rem;">
        <!-- Panel 1: Mon/Wed -->
        <details class="group accordion-panel">
          <summary class="accordion-summary">
            <div>
              <h3 class="font-heading text-deep-sea text-xl md:text-[1.5rem] font-semibold">Monday &amp; Wednesday</h3>
              <p class="text-driftwood font-body font-medium text-xs tracking-wide mt-1">Ages 9–12 &nbsp;·&nbsp; 9:00 AM – 2:00 PM</p>
            </div>
            <span class="accordion-chevron">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:00 AM</span><span>Morning meeting and check-in with advisor</span></div>
              <div class="schedule-row"><span class="schedule-time">9:10 AM</span><span>Gardening and gentle exercise outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:40 AM</span><span>Academic Lesson 1: Math (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:15 AM</span><span>Rest (5 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:20 AM</span><span>Academic Lesson 2: Science (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:55 AM</span><span>Lunch outside (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Academic Lesson 3: Reading &amp; Writing (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:05 PM</span><span>Rest (5 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:10 PM</span><span>Academic Lesson 4: Geography (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:45 PM</span><span>Self-projects / Individual tutoring with guidance (1 hr)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:45 PM</span><span>Clean up and end-of-day meeting</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal and pick-up</span></div>
            </div>
          </div>
        </details>

        <!-- Panel 2: Tue/Thu Morning -->
        <details class="group accordion-panel">
          <summary class="accordion-summary">
            <div>
              <h3 class="font-heading text-deep-sea text-xl md:text-[1.5rem] font-semibold">Tuesday &amp; Thursday Morning</h3>
              <p class="text-driftwood font-body font-medium text-xs tracking-wide mt-1">Ages 5–8 &nbsp;·&nbsp; 9:00–11:30 AM</p>
            </div>
            <span class="accordion-chevron">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:00 AM</span><span>Morning meeting and check-in with advisor</span></div>
              <div class="schedule-row"><span class="schedule-time">9:10 AM</span><span>Gentle stretching exercises and guided play (40 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">9:50 AM</span><span>Academic Lesson 1: Science with hands-on projects (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:20 AM</span><span>Rest and play (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:30 AM</span><span>Academic Lesson 2: Reading &amp; Writing (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Lunch and play outside (25 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:25 AM</span><span>Closing circle (5 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Dismissal and pick-up</span></div>
            </div>
          </div>
        </details>

        <!-- Panel 3: Tue/Thu Afternoon -->
        <details class="group accordion-panel">
          <summary class="accordion-summary">
            <div>
              <h3 class="font-heading text-deep-sea text-xl md:text-[1.5rem] font-semibold">Tuesday &amp; Thursday Afternoon</h3>
              <p class="text-driftwood font-body font-medium text-xs tracking-wide mt-1">Ages 5–8 &nbsp;·&nbsp; 11:30 AM–2:00 PM</p>
            </div>
            <span class="accordion-chevron">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">11:30 AM</span><span>Greeting, meet with advisor, and lunch outside (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:00 PM</span><span>Academic Lesson 1: Science with hands-on projects (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:30 PM</span><span>Rest and play (10 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:40 PM</span><span>Academic Lesson 2: Reading &amp; Writing (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:10 PM</span><span>Gentle stretching exercises and guided play (40 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:50 PM</span><span>Closing circle (5 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal and pick-up</span></div>
            </div>
          </div>
        </details>

        <!-- Panel 4: Friday -->
        <details class="group accordion-panel">
          <summary class="accordion-summary">
            <div>
              <h3 class="font-heading text-deep-sea text-xl md:text-[1.5rem] font-semibold">Friday — All Ages</h3>
              <p class="text-driftwood font-body font-medium text-xs tracking-wide mt-1">Ages 5–12 &nbsp;·&nbsp; 9:00 AM – 2:00 PM</p>
            </div>
            <span class="accordion-chevron">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </span>
          </summary>
          <div class="accordion-content">
            <div class="schedule-grid">
              <div class="schedule-row"><span class="schedule-time">9:00 AM</span><span>Meeting on the beach, greeting</span></div>
              <div class="schedule-row"><span class="schedule-time">9:10 AM</span><span>Surfing (if available) or somatic exercises (80 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">10:30 AM</span><span>Community service: beach cleanup (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:00 AM</span><span>Lunch and clean-up (45 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">11:45 AM</span><span>Return to center</span></div>
              <div class="schedule-row"><span class="schedule-time">12:00 PM</span><span>Academic Lesson 1: Animal Science (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:35 PM</span><span>Rest (5 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">12:40 PM</span><span>Academic Lesson 2: Entrepreneurship (35 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:15 PM</span><span>Self-projects / Older kids read to younger kids / Reading with therapy dogs / Individual tutoring (30 min)</span></div>
              <div class="schedule-row"><span class="schedule-time">1:45 PM</span><span>Clean up and end-of-day meeting</span></div>
              <div class="schedule-row"><span class="schedule-time">2:00 PM</span><span>Dismissal and pick-up</span></div>
            </div>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══ AFTER SCHOOL ENRICHMENT ═══ -->
  <section id="after-school" class="py-20" style="background-color: #E8D5B7;">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-12">
        <h2 class="font-heading text-deep-sea mb-6">After School Enrichment</h2>
        <div class="w-12 h-0.5 bg-sea-glass mx-auto mb-8"></div>
        <p class="text-driftwood font-body font-medium text-sm tracking-wide mb-8">
          Monday – Friday &nbsp;|&nbsp; 3:00 – 4:00 PM &nbsp;|&nbsp; Ages 5–12
        </p>
        <p class="text-[0.95rem] leading-relaxed max-w-3xl mx-auto" style="color: #4A5859;">
          One-hour enrichment classes open to all children — homeschooled and traditional school
          students alike. Each day offers two groups to choose from, covering hands-on arts, music,
          culinary skills, life skills, and strategy. No two days are the same.
        </p>
      </div>

      <div class="enrichment-grid">
        <!-- Monday -->
        <div class="enrichment-card">
          <h3 class="font-heading text-deep-sea text-xl font-semibold mb-4">Monday</h3>
          <div class="enrichment-groups">
            <div class="enrichment-group">
              <span class="enrichment-label">Group 1</span>
              <span class="enrichment-activity">Gardening Club</span>
            </div>
            <div class="enrichment-group">
              <span class="enrichment-label">Group 2</span>
              <span class="enrichment-activity">Music Lesson (Piano)</span>
            </div>
          </div>
        </div>

        <!-- Tuesday -->
        <div class="enrichment-card">
          <h3 class="font-heading text-deep-sea text-xl font-semibold mb-4">Tuesday</h3>
          <div class="enrichment-groups">
            <div class="enrichment-group">
              <span class="enrichment-label">Group 1</span>
              <span class="enrichment-activity">Painting</span>
            </div>
            <div class="enrichment-group">
              <span class="enrichment-label">Group 2</span>
              <span class="enrichment-activity">Culinary Arts</span>
            </div>
          </div>
        </div>

        <!-- Wednesday -->
        <div class="enrichment-card">
          <h3 class="font-heading text-deep-sea text-xl font-semibold mb-4">Wednesday</h3>
          <div class="enrichment-groups">
            <div class="enrichment-group">
              <span class="enrichment-label">Group 1</span>
              <span class="enrichment-activity">Knitting Class</span>
            </div>
            <div class="enrichment-group">
              <span class="enrichment-label">Group 2</span>
              <span class="enrichment-activity">Music Lesson (Guitar)</span>
            </div>
          </div>
        </div>

        <!-- Thursday -->
        <div class="enrichment-card">
          <h3 class="font-heading text-deep-sea text-xl font-semibold mb-4">Thursday</h3>
          <div class="enrichment-groups">
            <div class="enrichment-group">
              <span class="enrichment-label">Group 1</span>
              <span class="enrichment-activity">Drawing</span>
            </div>
            <div class="enrichment-group">
              <span class="enrichment-label">Group 2</span>
              <span class="enrichment-activity">Chess Club</span>
            </div>
          </div>
        </div>

        <!-- Friday -->
        <div class="enrichment-card">
          <h3 class="font-heading text-deep-sea text-xl font-semibold mb-4">Friday</h3>
          <div class="enrichment-groups">
            <div class="enrichment-group enrichment-group--single">
              <span class="enrichment-activity">Band Practice</span>
              <span class="enrichment-note">Advanced music students</span>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <p class="font-body font-light text-lg mb-8" style="color: #4A5859;">
          Open to all families in the community — not just homeschoolers.
        </p>
        <Button variant="primary" href="mailto:info@shorelinescholars.org">Get in Touch</Button>
      </div>
    </div>
  </section>

  <!-- ═══ EDUCATIONAL ECOSYSTEM ═══ -->
  <section id="ecosystem" class="bg-warm-sand/15 py-24 md:py-32">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-heading text-deep-sea mb-6">The Educational Ecosystem</h2>
        <div class="w-16 h-0.5 bg-sea-glass mx-auto"></div>
      </div>

      <Ecosystem client:load />

      <p class="text-[0.95rem] leading-relaxed text-center max-w-2xl mx-auto">
        Each pillar of the Shoreline Scholars Educational Ecosystem strengthens the others.
        A Friday morning spent cleaning the beach is outdoor learning, community service,
        and environmental science in one activity. A Wednesday afternoon self-project might
        combine entrepreneurship, creative arts, and financial literacy. This isn't a
        checklist — it's how learning naturally works when you stop separating it into boxes.
      </p>
    </div>
  </section>

  <CallToAction
    heading="Be Part of the Journey"
    description="We're building something special in Indialantic. Whether you're a family looking to enroll, a community member who wants to volunteer, or a supporter who believes in our mission — we'd love to hear from you."
  />

  <Footer />
</Layout>

<style>
  /* ─── Curriculum Cards ─── */
  .curriculum-card {
    background: rgba(232, 213, 183, 0.25);
    border-left: 4px solid #5AAFA6;
    border-radius: 1rem;
    padding: 2rem 2.25rem;
  }

  .curriculum-group {
    margin-bottom: 1.25rem;
  }

  .curriculum-group:last-of-type {
    margin-bottom: 0;
  }

  .curriculum-label {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #B8977E;
    display: block;
    margin-bottom: 0.2rem;
  }

  .curriculum-courses {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.92rem;
    color: #4A5859;
    line-height: 1.6;
  }

  .curriculum-note {
    font-family: var(--font-body);
    font-weight: 400;
    font-style: italic;
    font-size: 0.82rem;
    color: #B8977E;
    margin-top: 1.5rem;
    line-height: 1.5;
  }

  /* ─── Accordion ─── */
  details summary::-webkit-details-marker,
  details summary::marker {
    display: none;
    content: '';
  }
  details summary {
    list-style: none;
  }

  .accordion-panel {
    background: rgba(232, 213, 183, 0.25);
    border-radius: 1rem;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }
  .accordion-panel:hover {
    box-shadow: 0 2px 12px rgba(27, 79, 82, 0.06);
  }
  .accordion-panel[open] {
    box-shadow: 0 2px 16px rgba(27, 79, 82, 0.08);
  }

  /* Remove focus outline gaps */
  .accordion-summary:focus {
