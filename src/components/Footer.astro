---
const year = new Date().getFullYear();
---

<footer class="bg-deep-sea text-shell-white/80">
  <div class="max-w-6xl mx-auto px-6 py-12 text-center">
    <p class="font-heading text-xl text-shell-white font-medium mb-2">
      Shoreline Scholars
    </p>
    <p class="text-sm font-light mb-6">
      Indialantic, Florida
    </p>
    <div class="flex items-center justify-center" style="gap: 1.25rem; margin-bottom: 1.5rem;">
      <a href="https://instagram.com/shorelinescholars" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
      </a>
      <a href="https://www.facebook.com/profile.php?id=61587631643807" target="_blank" rel="noopener noreferrer" class="footer-social" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
    </div>
    <div class="w-12 h-px bg-sea-glass/40 mx-auto mb-6"></div>
    <p class="text-xs text-shell-white/60">
      &copy; {year} Shoreline Scholars. All rights reserved.
    </p>
  </div>
<style>
  .footer-social {
    color: rgba(250, 247, 242, 0.6);
    transition: color 0.2s ease;
  }
  .footer-social:hover {
    color: #5AAFA6;
  }
</style>
</footer>
