---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Our Vision', href: '/vision' },
  { label: 'About', href: '/#about' },
  { label: 'Team', href: '/#team' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-shell-white/95 backdrop-blur-sm border-b border-warm-sand/30">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo + Wordmark -->
    <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
      <img src="/logo.png" alt="" class="h-8 md:h-9 w-auto" />
      <span class="font-heading text-deep-sea text-2xl md:text-[1.7rem] font-bold tracking-wide">Shoreline Scholars</span>
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="font-body font-medium text-[0.85rem] text-deep-sea/80 hover:text-shoreline transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-deep-sea p-2"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden bg-shell-white border-t border-warm-sand/30 px-6 pb-4">
    <ul class="flex flex-col gap-3">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="block font-body font-medium text-[0.85rem] text-deep-sea/80 hover:text-shoreline py-2 transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Smooth scroll for same-page navigation
  document.querySelectorAll('header a[href]').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index.html';

      if (!isHomePage) return; // Let normal navigation happen on other pages

      // "Home" link — scroll to top
      if (href === '/') {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        menu?.classList.add('hidden');
        return;
      }

      // Anchor links like /#about, /#team, /#contact
      if (href?.startsWith('/#')) {
        const targetId = href.slice(2); // remove "/#"
        const target = document.getElementById(targetId);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth' });
          menu?.classList.add('hidden');
        }
      }
    });
  });
</script>
