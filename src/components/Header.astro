---
const navLinks = [
  { label: 'Our Vision', href: '/vision' },
  { label: 'Support', href: '/support' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-shell-white/95 backdrop-blur-sm border-b border-warm-sand/30">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo + Wordmark -->
    <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity">
      <img src="/logo.png" alt="" class="h-7 md:h-8 w-auto" />
      <span class="font-heading text-deep-sea text-2xl md:text-[1.7rem] font-bold tracking-wide">Shoreline Scholars</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(link => {
        const isActive = currentPath === link.href;
        return (
          <a
            href={link.href}
            class={`font-body font-medium text-[0.85rem] transition-colors ${isActive ? 'text-shoreline' : 'text-deep-sea/80 hover:text-shoreline'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="#get-involved"
        class="get-involved-btn inline-block font-body font-semibold text-[0.8rem] uppercase tracking-[0.15em] px-6 py-2.5 rounded-[6px] transition-all duration-200 cursor-pointer bg-sunrise text-white hover:brightness-110"
      >
        Get Involved
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-deep-sea p-2"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden bg-shell-white border-t border-warm-sand/30 px-6 pb-4">
    <ul class="flex flex-col gap-3">
      {navLinks.map(link => {
        const isActive = currentPath === link.href;
        return (
          <li>
            <a
              href={link.href}
              class={`block font-body font-medium text-[0.85rem] py-2 transition-colors ${isActive ? 'text-shoreline' : 'text-deep-sea/80 hover:text-shoreline'}`}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
      <li>
        <a
          href="#get-involved"
          class="get-involved-btn inline-block font-body font-semibold text-[0.8rem] uppercase tracking-[0.15em] px-6 py-2.5 rounded-[6px] transition-all duration-200 cursor-pointer bg-sunrise text-white hover:brightness-110 mt-1"
        >
          Get Involved
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Smooth scroll for "Get Involved" button on any page
  document.querySelectorAll('a.get-involved-btn').forEach(link => {
    link.addEventListener('click', (e) => {
      const target = document.getElementById('get-involved');
      if (target) {
        e.preventDefault();
        const header = document.querySelector('header') as HTMLElement;
        const offset = header?.offsetHeight || 60;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
        menu?.classList.add('hidden');
      }
    });
  });
</script>
