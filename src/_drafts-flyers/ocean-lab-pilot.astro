---
// Standalone flyer — designed for print / PDF export (no site layout)
---
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ocean Lab — Shoreline Scholars Flyer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style is:inline>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --deep-sea: #1B4F52;
      --shoreline: #2A7F62;
      --sea-glass: #5AAFA6;
      --warm-sand: #E8D5B7;
      --driftwood: #B8977E;
      --shell-white: #FAF7F2;
      --sunrise: #E8956D;
      --font-heading: 'Cormorant Garamond', Georgia, serif;
      --font-body: 'Raleway', system-ui, sans-serif;
    }

    html, body { height: 100%; background: var(--shell-white); color: var(--deep-sea); }

    /* ═══════════════════════════════════
       PAGE SHELL — exactly one printed page
       ═══════════════════════════════════ */
    .flyer {
      width: 8.5in;
      max-width: 100%;
      height: 11in;
      max-height: 100vh;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow: hidden;
    }

    @media print {
      html, body { height: 11in; }
      .flyer { max-height: 11in; }
      @page { size: letter; margin: 0; }
    }

    /* ═══════════════════════════════════
       HEADER — compact gradient banner
       ═══════════════════════════════════ */
    .hero {
      flex-shrink: 0;
      background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 50%, #5AAFA6 100%);
      text-align: center;
      padding: 0.55rem 2rem 0.5rem;
    }

    .hero-title {
      font-family: var(--font-heading);
      font-weight: 500;
      font-size: 2.4rem;
      color: var(--shell-white);
      line-height: 1;
      margin-bottom: 0.1rem;
    }

    .hero-location {
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.55rem;
      color: rgba(250, 247, 242, 0.6);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 0.2rem;
    }

    .hero-subtitle {
      font-family: var(--font-heading);
      font-weight: 500;
      font-size: 1.15rem;
      font-style: italic;
      color: var(--warm-sand);
      letter-spacing: 0.02em;
    }

    /* ═══════════════════════════════════
       MAIN — flex:1, owns all middle content
       ═══════════════════════════════════ */
    .main-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding: 0.35rem 0;
      min-height: 0;
    }

    /* --- Body: two-column text + landscape photo --- */
    .body-section {
      flex-shrink: 0;
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 0 1.2rem;
    }

    .body-left {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      align-self: stretch;
    }

    .body-right {
      flex: 1.5;
      border-radius: 12px;
      overflow: hidden;
      line-height: 0;
      position: relative;
    }

    .body-right img {
      width: 100%;
      height: auto;
      display: block;
    }

    .badge {
      display: inline-block;
      align-self: flex-start;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.55rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--shell-white);
      background: var(--shoreline);
      padding: 0.2rem 0.6rem;
      border-radius: 3px;
      margin-bottom: 0.25rem;
    }

    .body-heading {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 1.5rem;
      color: var(--deep-sea);
      line-height: 1.15;
      margin-bottom: 0.05rem;
    }

    .body-subheading {
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 0.68rem;
      color: var(--driftwood);
      margin-bottom: 0.35rem;
    }

    .activity-list {
      list-style: none;
      display: flex;
      flex-direction: column;
    }

    .activity-list li {
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--deep-sea);
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.25rem 0;
      border-bottom: 1px solid rgba(232, 213, 183, 0.35);
    }

    .activity-list li:last-child { border-bottom: none; }

    .act-icon {
      width: 24px;
      height: 24px;
      min-width: 24px;
      border-radius: 50%;
      background: rgba(90, 175, 166, 0.12);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.65rem;
    }

    .body-quote {
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 0.7rem;
      font-style: italic;
      color: var(--driftwood);
      line-height: 1.5;
      border-left: 2px solid var(--sea-glass);
      padding-left: 0.5rem;
      margin-top: 0.3rem;
    }

    .photo-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1.5rem 0.5rem 0.4rem;
      background: linear-gradient(to top, rgba(27, 79, 82, 0.7) 0%, transparent 100%);
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.55rem;
      color: var(--shell-white);
      text-align: center;
      letter-spacing: 0.03em;
    }

    /* --- Portraits: fill remaining main space --- */
    .portraits-section {
      display: flex;
      gap: 10px;
      padding: 0 0.8rem;
    }

    .portrait-photo {
      flex: 1;
      border-radius: 12px;
      overflow: hidden;
      position: relative;
      line-height: 0;
      min-width: 0;
    }

    .portrait-photo img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* --- Description --- */
    .description-block {
      flex-shrink: 0;
      background: rgba(232, 213, 183, 0.22);
      padding: 0.5rem 1.8rem;
      text-align: center;
    }

    .description-block p {
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 0.72rem;
      color: var(--deep-sea);
      line-height: 1.65;
    }

    /* --- Info strip --- */
    .info-strip {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.2rem;
      padding: 0.4rem 1.4rem;
      border-top: 1px solid rgba(232, 213, 183, 0.5);
    }

    .info-item {
      text-align: center;
      padding: 0 0.8rem;
    }

    .info-value {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 1rem;
      color: var(--deep-sea);
      display: block;
      line-height: 1.15;
    }

    .info-label {
      font-family: var(--font-body);
      font-weight: 500;
      font-size: 0.42rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--driftwood);
    }

    .info-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--driftwood);
      flex-shrink: 0;
    }

    /* ═══════════════════════════════════
       FOOTER — horizontal bar, pinned bottom
       ═══════════════════════════════════ */
    .footer {
      flex-shrink: 0;
      background: linear-gradient(135deg, #1B4F52 0%, #2A7F62 60%, #1B4F52 100%);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.45rem 1.4rem;
    }

    .footer-left {}

    .footer-tagline {
      font-family: var(--font-heading);
      font-weight: 500;
      font-size: 0.82rem;
      font-style: italic;
      color: rgba(250, 247, 242, 0.6);
      line-height: 1.2;
    }

    .footer-url {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 1.15rem;
      color: var(--shell-white);
      line-height: 1.2;
    }

    .footer-subtitle {
      font-family: var(--font-body);
      font-weight: 400;
      font-size: 0.48rem;
      color: rgba(250, 247, 242, 0.4);
    }

    .footer-btn {
      display: inline-block;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.4rem 1.4rem;
      border-radius: 5px;
      text-decoration: none;
      color: white;
      background: var(--sunrise);
      flex-shrink: 0;
    }
  </style>
</head>
<body>
  <div class="flyer">

    <!-- HEADER -->
    <header class="hero">
      <h1 class="hero-title">Shoreline Scholars</h1>
      <p class="hero-location">at Nance Park &bull; Indialantic, FL</p>
      <p class="hero-subtitle">An Oceanfront Learning Adventure</p>
    </header>

    <!-- MAIN CONTENT -->
    <main class="main-content">

      <!-- Two-column: text + landscape photo -->
      <section class="body-section">
        <div class="body-left">
          <span class="badge">New Pilot Program</span>
          <h2 class="body-heading">Join Our Ocean Lab</h2>
          <p class="body-subheading">Hands-on marine science &amp; nature exploring</p>
          <ul class="activity-list">
            <li><span class="act-icon">🐚</span><span>Tide Pool Studies</span></li>
            <li><span class="act-icon">🌊</span><span>Beach Ecology</span></li>
            <li><span class="act-icon">⚡</span><span>Creative STEM Projects</span></li>
            <li><span class="act-icon">📓</span><span>Nature Journaling</span></li>
            <li><span class="act-icon">🧘</span><span>Mindfulness by the Sea</span></li>
          </ul>
          <p class="body-quote">
            Led by experienced educators in a small, relationship-centered group right by the ocean.
          </p>
        </div>
        <div class="body-right">
          <img src="/images/flyers/ocean-lab-lesson.jpg" alt="Outdoor learning on the shoreline">
          <div class="photo-caption">Outdoor Learning on the Shoreline</div>
        </div>
      </section>

      <!-- Portrait photos — fill remaining main space -->
      <section class="portraits-section">
        <div class="portrait-photo">
          <img src="/images/flyers/ocean-lab-art.jpg" alt="Ocean discovery at the shoreline">
          <div class="photo-caption">Ocean Discovery</div>
        </div>
        <div class="portrait-photo">
          <img src="/images/flyers/ocean-lab-discovery.jpg" alt="Creative exploration on the beach">
          <div class="photo-caption">Creative Exploration</div>
        </div>
      </section>

      <!-- Description -->
      <div class="description-block">
        <p>Shoreline Scholars is a nonprofit beachside learning community in Indialantic, Florida. Our Ocean Lab pilot brings children to the shoreline for hands-on exploration — learning marine science, ecology, and creative expression right where the waves meet the sand.</p>
      </div>

      <!-- Info strip -->
      <div class="info-strip">
        <div class="info-item">
          <span class="info-value">1 Day</span>
          <span class="info-label">Per Week</span>
        </div>
        <div class="info-dot"></div>
        <div class="info-item">
          <span class="info-value">Ages 5–12</span>
          <span class="info-label">All Welcome</span>
        </div>
        <div class="info-dot"></div>
        <div class="info-item">
          <span class="info-value">Small Group</span>
          <span class="info-label">Learning</span>
        </div>
        <div class="info-dot"></div>
        <div class="info-item">
          <span class="info-value">Nonprofit</span>
          <span class="info-label">Organization</span>
        </div>
      </div>

    </main>

    <!-- FOOTER -->
    <footer class="footer">
      <div class="footer-left">
        <div class="footer-tagline">Where curiosity meets the coastline</div>
        <div class="footer-url">www.shorelinescholars.org</div>
        <div class="footer-subtitle">A nonprofit beachside learning community for children ages 5–12</div>
      </div>
      <a href="https://shorelinescholars.org" class="footer-btn">Learn More</a>
    </footer>

  </div>
</body>
</html>
