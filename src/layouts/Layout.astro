---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  // ogImage?: string;
  ogType?: string;
  canonical?: string;
}

const {
  title = 'Shoreline Scholars — Where Curiosity Meets the Coastline',
  description = 'A relational, hands-on learning community designed to support the whole-child development of homeschool families in Melbourne Beach, Indialantic, and the greater Brevard County Space Coast.',
  // ogImage = '/og-image.png',
  ogType = 'website',
  canonical
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://shorelinescholars.org');
const canonicalUrl = canonical
  ? new URL(canonical, siteUrl).toString()
  : new URL(Astro.url.pathname, siteUrl).toString();
// const ogImageUrl = new URL(ogImage, siteUrl).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': ['EducationalOrganization', 'LocalBusiness'],
  '@id': new URL('/#organization', siteUrl).toString(),
  name: 'Shoreline Scholars',
  url: siteUrl.toString(),
  logo: new URL('/logo.png', siteUrl).toString(),
  image: new URL('/logo.png', siteUrl).toString(),
  email: 'shorelinescholars@gmail.com',
  telephone: '+1-321-345-1468',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '2010 Oak St',
    addressLocality: 'Melbourne Beach',
    addressRegion: 'FL',
    postalCode: '32951',
    addressCountry: 'US'
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Wednesday', 'Thursday', 'Friday'],
      opens: '09:30',
      closes: '14:00'
    }
  ],
  areaServed: [
    { '@type': 'City', name: 'Melbourne Beach' },
    { '@type': 'City', name: 'Indialantic' },
    { '@type': 'City', name: 'Satellite Beach' },
    { '@type': 'City', name: 'Indian Harbour Beach' },
    { '@type': 'City', name: 'Melbourne' },
    { '@type': 'AdministrativeArea', name: 'Brevard County' }
  ],
  sameAs: [
    'https://www.instagram.com/shorelinescholars',
    'https://www.facebook.com/profile.php?id=61587631643807'
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Shoreline Scholars" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {/* <meta property="og:image" content={ogImageUrl} /> */}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {/* <meta name="twitter:image" content={ogImageUrl} /> */}

    <!-- Organization schema -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-G9Q30BB442"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G9Q30BB442');
    </script>

    <!-- Google Fonts: Cormorant Garamond + Raleway -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Tally Form Embed -->
    <script is:inline async src="https://tally.so/widgets/embed.js"></script>

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
